  "sleep": [
    {
      "text": "آية الكرسي قبل النوم.",
      "repeat": 1,
      "source": "البخاري",
      "ref": "https://islamqa.info/ar/answers/145543"
    },
    {
      "text": "آخر آيتين من سورة البقرة قبل النوم.",
